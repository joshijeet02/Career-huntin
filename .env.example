# Backend runtime
DATABASE_URL=sqlite:///./jobs_automation.db

# OpenAI integration for /coach/respond
OPENAI_API_KEY=sk-your-key-here
OPENAI_COACH_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Backend auth and encrypted coach storage
BACKEND_API_KEY=replace-with-strong-random-key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=replace-with-generated-fernet-key
COACH_RETENTION_DAYS=90
